# ==============================================================================
# XingRin 远程 Worker 环境配置
# ==============================================================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 修改下方配置，指向你的主机服务器
#   3. docker compose up -d --build
# ==============================================================================

# ===================== Prefect 配置 =====================
# 主机的 Prefect API 地址（必须是公网可访问的）
PREFECT_API_URL=http://你的主机公网IP:4200/api

# ===================== 数据库配置 =====================
# 主机的 PostgreSQL 地址（必须是公网可访问的）
DB_HOST=你的主机公网IP
DB_PORT=5432
DB_NAME=xingrin
DB_USER=xingrin
DB_PASSWORD=你的数据库密码

# ===================== Redis 配置 =====================
REDIS_HOST=你的主机公网IP
REDIS_PORT=6379
