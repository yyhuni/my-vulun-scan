# ==================== 数据库配置（PostgreSQL） ====================
# DB_HOST 决定使用本地容器还是远程数据库：
#   - postgres / localhost / 127.0.0.1 → 启动本地 PostgreSQL 容器
#   - 其他地址（如 192.168.1.100）    → 使用远程数据库，不启动本地容器
DB_HOST=postgres
DB_PORT=5432
DB_NAME=xingrin
DB_USER=postgres
DB_PASSWORD=123.com
# Prefect Server 使用的数据库名（与应用库分开，便于运维和备份）
PREFECT_DB_NAME=prefect

# ==================== Redis 配置 ====================
# 在 Docker 网络中，Redis 服务名称为 redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ==================== 服务端口配置 ====================
# SERVER_PORT 为 Django / Daphne 对外端口
# PREFECT_UI_PORT 为 Prefect Web UI 对外端口
SERVER_PORT=8888
PREFECT_UI_PORT=4200

# ==================== Django 核心配置 ====================
# 生产环境务必更换为随机强密钥
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
# 是否开启调试模式（生产环境请保持 False）
DEBUG=False
# 允许访问的主机列表（逗号分隔）
ALLOWED_HOSTS=localhost,127.0.0.1,server
# 允许的前端来源地址（用于 CORS）
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==================== 路径配置（容器内路径） ====================
# 扫描结果保存目录
SCAN_RESULTS_DIR=/app/backend/results
# Django 日志目录
# 注意：如果留空或删除此变量，日志将只输出到 Docker 控制台（标准输出），不写入文件
# LOG_DIR=/app/backend/logs

# ==================== 日志级别配置 ====================
# 应用日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# Prefect 日志级别：DEBUG / INFO / WARNING / ERROR
PREFECT_LOGGING_LEVEL=INFO
# 是否记录命令执行日志（大量扫描时会增加磁盘占用）
ENABLE_COMMAND_LOGGING=false

# ==================== Prefect 配置 ====================
# 容器内部访问的 Prefect API 地址
PREFECT_API_URL=http://server:4200/api
# 默认工作池名称
PREFECT_DEFAULT_WORK_POOL_NAME=development-pool
# Prefect Server 使用的数据库连接串（建议与应用数据库分库）
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${PREFECT_DB_NAME}
