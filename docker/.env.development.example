# ==================== 数据库配置（PostgreSQL） ====================
DB_NAME=xingrin_dev
DB_USER=postgres
DB_PASSWORD=123.com
DB_PORT=5432
DB_HOST=postgres
# Prefect Server 使用的数据库名
PREFECT_DB_NAME=prefect_dev

# ==================== Redis 配置 ====================
# 在 Docker 网络中，Redis 服务名称为 redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ==================== 服务端口配置 ====================
# 开发环境通常使用相同的端口映射，但在单机多实例部署时可能需要修改
SERVER_PORT=8888
PREFECT_UI_PORT=4200

# ==================== Django 核心配置 ====================
# 开发环境密钥（不安全，仅供开发使用）
DJANGO_SECRET_KEY=django-insecure-dev-key-123456
# 是否开启调试模式（开发环境开启）
DEBUG=True
# 允许的前端来源地址（开发环境允许所有）
CORS_ALLOWED_ORIGINS=*

# ==================== 路径配置（容器内路径） ====================
# 扫描结果保存目录
SCAN_RESULTS_DIR=/app/backend/results
# Django 日志目录
# 开发环境通常也保留文件日志以便排查问题，如想查看实时流日志可将其留空
LOG_DIR=/app/backend/logs

# ==================== 日志级别配置 ====================
# 开发环境使用 DEBUG 级别查看详细信息
LOG_LEVEL=DEBUG
# Prefect 日志级别
PREFECT_LOGGING_LEVEL=DEBUG
# 开启命令详细日志，便于调试扫描工具的输出问题
ENABLE_COMMAND_LOGGING=true

# ==================== Prefect 配置 ====================
# 容器内部访问的 Prefect API 地址
PREFECT_API_URL=http://server:4200/api
# 工作池名称配置
PREFECT_SCAN_WORK_POOL_NAME=scan-pool
PREFECT_MAINTENANCE_WORK_POOL_NAME=maintenance-pool
# Prefect Server 使用的数据库连接串
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${PREFECT_DB_NAME}

# ==================== Worker 配置 ====================
# Worker 并发限制（开发环境可以设置小一点）
WORKER_LIMIT=3
