# 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# 时区设置
TZ=Asia/Shanghai

# API 密钥（如果扫描工具需要）
# API_KEY=your_api_key_here

# 目标域名
# TARGET_DOMAIN=example.com

# 扫描模式
# SCAN_MODE=full

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=xingrin

# Redis 配置（如果后续添加任务队列）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
