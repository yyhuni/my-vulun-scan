# Django 配置
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL 数据库配置
DB_ENGINE=django.db.backends.postgresql
DB_NAME=xingrin
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# 服务器配置
SERVER_PORT=8888

# CORS 配置（前端地址）
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==================== 国际化配置 ====================
# 语言代码（默认：zh-hans）
# 可选值：zh-hans（简体中文）, en-us（英文）
# LANGUAGE_CODE=zh-hans

# 时区（默认：Asia/Shanghai）
# 可选值：Asia/Shanghai, UTC, America/New_York 等
# TIME_ZONE=Asia/Shanghai

# ==================== Celery 配置 ====================
# Worker 预取任务数（默认：1）
# 建议：保持为 1，避免任务堆积
# CELERY_WORKER_PREFETCH_MULTIPLIER=1

# 任务硬超时（单位：秒，默认：3600 = 1小时）
# 超时后强制终止任务，无法捕获异常
# CELERY_TASK_TIME_LIMIT=3600

# 任务软超时（单位：秒，默认：3000 = 50分钟）
# 超时后抛出 SoftTimeLimitExceeded 异常，允许清理资源
# CELERY_TASK_SOFT_TIME_LIMIT=3000

# ==================== 扫描结果存储配置 ====================
# 扫描结果存储目录（必须配置）
# 开发环境建议：使用项目目录下的 results 目录
# 生产环境建议：使用独立的数据目录，如 /data/scans
SCAN_RESULTS_DIR=/results

# 扫描结果保留时间（单位：天）
# 默认：7 天
# SCAN_RETENTION_DAYS=7

# ==================== Prefect 配置 ====================
# Prefect API 服务器地址
# 默认：http://localhost:4200/api
# 生产环境需修改为实际的 Prefect Server 地址
# PREFECT_API_URL=http://localhost:4200/api

# Prefect 数据库连接 URL（可选，不配置则使用 Django 数据库信息自动构建）
# 格式：postgresql+asyncpg://user:password@host:port/database
# PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://postgres:password@localhost:5432/prefect

# Prefect 默认工作池名称
# 默认：default
# PREFECT_DEFAULT_WORK_POOL_NAME=default

# Prefect 日志级别
# 默认：INFO
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
# PREFECT_LOGGING_LEVEL=INFO

# Prefect 任务默认超时时间（单位：秒）
# 默认：3600 秒（1小时）
# PREFECT_TASK_DEFAULT_TIMEOUT_SECONDS=3600

# Prefect 任务默认重试次数
# 默认：3 次
# PREFECT_TASK_DEFAULT_RETRIES=3

# Prefect 任务重试延迟（单位：秒）
# 默认：60 秒
# PREFECT_TASK_DEFAULT_RETRY_DELAY_SECONDS=60

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 开发环境建议: DEBUG (输出详细调试信息)
# 生产环境建议: INFO 或 WARNING (减少日志量)
LOG_LEVEL=DEBUG

# 日志目录（用于文件日志）
# 开发环境：可留空（仅控制台）或使用项目目录
# 生产环境：建议配置到项目目录或系统日志目录
# 示例：/Users/yangyang/Desktop/scanner/logs
LOG_DIR=/logs

# 扫描模块日志级别（可单独控制，不设置则使用默认的 LOG_LEVEL）
# SCAN_LOG_LEVEL=DEBUG
# CELERY_LOG_LEVEL=INFO