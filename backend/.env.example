# Django 配置
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL 数据库配置
DB_ENGINE=django.db.backends.postgresql
DB_NAME=xingrin
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# 服务器配置
SERVER_PORT=8888

# CORS 配置（前端地址）
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==================== 扫描结果存储配置 ====================
# 扫描结果存储目录（必须配置）
# 开发环境建议：使用项目目录下的 results 目录
# 生产环境建议：使用独立的数据目录，如 /data/scans
SCAN_RESULTS_DIR=/results

# 扫描结果保留时间（单位：天）
# 默认：7 天
# SCAN_RETENTION_DAYS=7

# ==================== 命令执行配置 ====================
# 命令执行超时时间（单位：秒）
# 默认：3600 秒（60分钟）
# 建议：根据扫描工具的实际执行时间调整
COMMAND_TIMEOUT=3600

# 命令池最大并发数（单位：个）
# 默认：5 个
# 建议：根据服务器资源调整，避免并发过高导致资源耗尽
COMMAND_POOL_MAX_WORKERS=5

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 开发环境建议: DEBUG (输出详细调试信息)
# 生产环境建议: INFO 或 WARNING (减少日志量)
LOG_LEVEL=DEBUG

# 日志目录（用于文件日志）
# 开发环境：可留空（仅控制台）或使用项目目录
# 生产环境：建议配置到项目目录或系统日志目录
# 示例：/Users/yangyang/Desktop/scanner/logs
LOG_DIR=/logs

# 扫描模块日志级别（可单独控制，不设置则使用默认的 LOG_LEVEL）
# SCAN_LOG_LEVEL=DEBUG
# CELERY_LOG_LEVEL=INFO

# 命令输出日志（开发环境启用）
COMMAND_LOG_OUTPUT=True