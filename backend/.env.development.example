# ==================== 环境标识 ====================
ENVIRONMENT=development

# ==================== Django 配置 ====================
# 开发环境密钥（不用于生产）
SECRET_KEY=django-insecure-dev-key-replace-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== PostgreSQL 数据库配置 ====================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=xingrin_dev
DB_USER=<数据库用户名>
DB_PASSWORD=<数据库密码>
DB_HOST=<数据库地址>
DB_PORT=5432

# ==================== 服务器配置 ====================
SERVER_PORT=8888

# ==================== CORS 配置（前端地址）====================
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==================== 扫描结果存储配置 ====================
# 相对路径（推荐）：./results 表示 backend/results
# 绝对路径：/data/scanner/results
# 留空则使用项目默认路径
SCAN_RESULTS_DIR=./results

# ==================== Prefect 配置 ====================
# Prefect API 服务器地址
PREFECT_API_URL=http://localhost:4200/api

# Prefect Server 数据库配置
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/prefect_dev

# Prefect 日志级别
PREFECT_LOGGING_LEVEL=DEBUG

# Prefect 工作池
PREFECT_DEFAULT_WORK_POOL_NAME=development-pool

# ==================== 日志配置 ====================
LOG_LEVEL=DEBUG
# 相对路径：相对于 backend 目录
# 格式：./logs 表示 backend/logs
LOG_DIR=./logs

# ==================== 命令执行日志配置 ====================
# 开启命令执行日志记录（开发环境建议开启）
# 注意：日志文件将保存在对应的扫描目录中
ENABLE_COMMAND_LOGGING=true

# ==================== Redis 配置 ====================
# Redis 服务器配置（用于 Django Channels WebSocket 后端）
# 支持实时通知推送功能
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
