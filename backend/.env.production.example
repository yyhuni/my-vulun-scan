# ==================== 环境标识 ====================
ENVIRONMENT=production

# ==================== Django 配置 ====================
# 生产环境需要使用强密钥！可以用：python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-prod-key-replace-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== PostgreSQL 数据库配置 ====================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=xingrin_prod
DB_USER=prod_user
DB_PASSWORD=<生产数据库密码-请修改>
DB_HOST=<生产数据库地址-请修改>
DB_PORT=5432

# ==================== 服务器配置 ====================
SERVER_PORT=8888

# ==================== CORS 配置（前端地址）====================
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==================== 扫描结果存储配置 ====================
SCAN_RESULTS_DIR=./results

# ==================== Prefect 配置 ====================
# Prefect API 服务器地址
# 本地测试: http://localhost:4200/api
# 远程 Worker: http://your-server-ip:4200/api 或 https://prefect.yourdomain.com/api
PREFECT_API_URL=https://prefect.yourdomain.com/api

# Prefect Server 数据库配置（自动引用上面的数据库配置）
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/prefect_prod

# Prefect 日志级别
PREFECT_LOGGING_LEVEL=INFO

# Prefect 工作池（生产环境使用 Kubernetes 或 Docker）
PREFECT_DEFAULT_WORK_POOL_NAME=production-pool

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_DIR=./xingrin

# ==================== Redis 配置 ====================
# Redis 服务器配置（生产环境使用独立 Redis 服务器）
REDIS_HOST=<Redis服务器地址-请修改>
REDIS_PORT=6379
REDIS_DB=0
