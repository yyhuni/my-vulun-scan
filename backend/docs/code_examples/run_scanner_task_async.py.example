"""
运行扫描工具任务（异步版本）

负责运行单个子域名扫描工具（amass、subfinder 等）

与同步版本的差异：
1. 使用 asyncio.create_subprocess_shell 替代 subprocess.run
2. 支持 asyncio.CancelledError 取消机制
3. 异步等待进程完成
4. 正确清理被取消的进程
"""

import logging
import asyncio
import os
import uuid
from pathlib import Path
from datetime import datetime
from prefect import task

from apps.common.normalizer import normalize_domain
from apps.common.validators import validate_domain

logger = logging.getLogger(__name__)


@task(
    name='run_scanner_async',
    retries=2,
    retry_delay_seconds=10,
    log_prints=True
)
async def run_scanner_task_async(
    tool: str,
    target: str,
    result_dir: str,
    command: str,
    timeout: int
) -> str:
    """
    运行单个扫描工具（异步版本）
    
    Args:
        tool: 扫描工具名称（用于日志和文件命名）
        target: 目标域名
        result_dir: 结果目录（已拼接好完整路径）
        command: 扫描命令模板（如：'amass enum -passive -d {target} -o {output_file}'）
        timeout: 命令执行超时时间（秒）
    
    Returns:
        str: 结果文件路径，失败返回空字符串
    
    Raises:
        ValueError: 参数验证失败
        RuntimeError: 扫描执行失败
        asyncio.CancelledError: 任务被取消（会重新抛出）
    
    Note:
        - 支持取消操作：收到 CancelledError 时会终止外部进程
        - 使用异步 subprocess，不阻塞事件循环
        - 进程清理：取消或超时时会 kill 进程并等待其终止
    """
    logger.info("开始运行扫描工具（异步）: %s - 目标: %s", tool, target)
    
    # 进程对象（供清理使用）
    proc = None
    
    try:
        # 1. 验证参数
        if not tool:
            raise ValueError("工具名称不能为空")
        if not command:
            raise ValueError("扫描命令不能为空")
        if timeout <= 0:
            raise ValueError(f"超时时间必须大于0: {timeout}")
        if not result_dir:
            raise ValueError("结果目录不能为空")
        
        # 2. 规范化和验证域名
        try:
            normalized_target = normalize_domain(target)
            validate_domain(normalized_target)
            logger.debug("域名验证通过: %s -> %s", target, normalized_target)
            target = normalized_target
        except ValueError as e:
            error_msg = f"无效的目标域名: {target} - {e}"
            logger.error(error_msg)
            raise ValueError(error_msg) from e
        
        # 3. 验证结果目录
        result_path = Path(result_dir)
        if not result_path.exists():
            raise ValueError(f"结果目录不存在: {result_dir}")
        
        if not result_path.is_dir() or not os.access(result_path, os.W_OK):
            raise RuntimeError(f"目录 {result_path} 不可写")
        
        # 4. 生成输出文件路径
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        short_uuid = uuid.uuid4().hex[:4]
        file_prefix = f"{tool}_{timestamp}_{short_uuid}"
        
        output_file = result_path / f"{file_prefix}.txt"
        log_file = result_path / f"{file_prefix}.log"
        
        # 5. 构建命令
        actual_command = command.format(
            target=target,
            output_file=str(output_file)
        )
        
        logger.debug("执行命令: %s", actual_command)
        logger.debug("结果文件: %s", output_file)
        
        # 6. 异步执行扫描
        # 打开日志文件（用于记录 stderr）
        log_f = open(log_file, 'w', encoding='utf-8')
        
        try:
            # 创建异步子进程
            proc = await asyncio.create_subprocess_shell(
                actual_command,
                stdout=asyncio.subprocess.DEVNULL,  # 丢弃标准输出
                stderr=log_f,  # 错误输出到日志文件
            )
            
            # 异步等待进程完成（支持取消和超时）
            try:
                await asyncio.wait_for(
                    proc.communicate(),
                    timeout=timeout
                )
            except asyncio.TimeoutError:
                # 超时：终止进程
                logger.error("扫描工具 %s 执行超时（%d秒）", tool, timeout)
                proc.kill()
                await proc.wait()
                raise RuntimeError(f"扫描工具 {tool} 执行超时（{timeout}秒）")
            
            # 检查返回码
            if proc.returncode != 0:
                logger.warning(
                    "扫描工具 %s 返回非零状态码: %d",
                    tool, proc.returncode
                )
        
        finally:
            # 关闭日志文件
            log_f.close()
        
        # 7. 验证输出文件
        if not output_file.exists():
            logger.warning(
                "扫描工具 %s 未生成结果文件: %s",
                tool, output_file
            )
            return ""
        
        # 8. 检查文件大小
        file_size = output_file.stat().st_size
        if file_size == 0:
            logger.warning(
                "扫描工具 %s 生成的结果文件为空: %s",
                tool, output_file
            )
            return str(output_file)
        else:
            logger.info(
                "✓ 扫描完成（异步）: %s - 结果文件: %s (%.2f KB)",
                tool, output_file.name, file_size / 1024
            )
        
        return str(output_file)
    
    except asyncio.CancelledError:
        # 任务被取消
        logger.warning("扫描任务被取消: %s - 目标: %s", tool, target)
        
        # 清理：终止外部进程
        if proc and proc.returncode is None:
            logger.info("终止外部进程: %s (PID: %s)", tool, proc.pid)
            proc.kill()
            try:
                await asyncio.wait_for(proc.wait(), timeout=5)
                logger.info("✓ 进程已终止: %s", tool)
            except asyncio.TimeoutError:
                logger.error("✗ 进程终止超时: %s (PID: %s)", tool, proc.pid)
        
        # 重新抛出 CancelledError，让 Prefect 知道任务已取消
        raise
    
    except Exception as e:
        error_msg = f"扫描工具 {tool} 执行异常: {e}"
        logger.error(error_msg, exc_info=True)
        
        # 清理：终止外部进程（如果还在运行）
        if proc and proc.returncode is None:
            logger.info("清理进程: %s (PID: %s)", tool, proc.pid)
            proc.kill()
            try:
                await asyncio.wait_for(proc.wait(), timeout=5)
            except Exception:
                pass
        
        raise
