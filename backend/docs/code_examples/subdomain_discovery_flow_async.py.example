"""
子域名发现扫描 Flow（异步版本）

负责编排子域名发现扫描的完整流程

关键改动：
1. Flow 函数改为 async
2. 使用 asyncio.gather() 替代 .submit()
3. 导入异步版本的 run_scanner_task_async
4. 其他 Task 保持同步（merge、save）

优势：
- 支持正确的取消机制（on_cancellation handler 能触发）
- 协程比线程轻量（内存占用更低）
- 取消信号能正确传播到所有子任务
"""

from prefect import flow
from pathlib import Path
import logging
import asyncio  # ← 新增导入
from django.conf import settings

logger = logging.getLogger(__name__)

# 扫描工具配置（在 Flow 层管理）
SCANNER_CONFIGS = {
    'amass': {
        'command': 'amass enum -passive -d {target} -o {output_file}',
        'timeout': settings.SUBPROCESS_DEFAULT_TIMEOUT_SECONDS  # 默认 3600 秒
    },
    'subfinder': {
        'command': 'subfinder -d {target} -o {output_file}',
        'timeout': 1800  # subfinder 较快，使用更短的超时
    }
}


@flow(name="subdomain_discovery", log_prints=True)
async def subdomain_discovery_flow(  # ← 改为 async
    scan_id: int,
    target_name: str,
    target_id: int,
    scan_workspace_dir: str,
    engine_config: str = None
) -> dict:
    """
    子域名发现扫描流程（异步版本）
    
    编排步骤：
    1. 并行运行多个扫描工具（amass、subfinder）- 使用 asyncio.gather()
    2. 合并、解析并验证域名（一体化处理，高性能）
    3. 批量保存到数据库
    
    Args:
        scan_id: 扫描任务 ID
        target_name: 目标名称（域名）
        target_id: 目标 ID
        scan_workspace_dir: Scan 工作空间目录（由 Service 层创建）
        engine_config: 引擎配置（预留，暂未使用）
    
    Returns:
        dict: {
            'success': bool,
            'scan_id': int,
            'target': str,
            'scan_workspace_dir': str,
            'total': int,
            'executed_tasks': list
        }
    
    Raises:
        ValueError: 配置错误
        RuntimeError: 执行失败
        asyncio.CancelledError: 任务被取消
    """
    try:
        logger.info(
            "="*60 + "\n" +
            "开始子域名发现扫描（异步）\n" +
            f"  Scan ID: {scan_id}\n" +
            f"  Target: {target_name}\n" +
            f"  Workspace: {scan_workspace_dir}\n" +
            "="*60
        )
        
        # ==================== Step 1: 并行运行扫描工具 ====================
        # 导入异步版本的 Task
        from apps.scan.tasks.subdomain_discovery import (
            run_scanner_task_async,  # ← 使用异步版本
            merge_and_validate_task,
            save_domains_task
        )
        
        # 准备结果目录
        result_dir = str(Path(scan_workspace_dir) / 'subdomain_discovery')
        Path(result_dir).mkdir(parents=True, exist_ok=True)
        
        logger.info(
            "Step 1: 并行运行扫描工具（%s）",
            ', '.join(SCANNER_CONFIGS.keys())
        )
        
        # ==================== 关键改动：使用 asyncio.gather ====================
        # 创建协程任务列表
        tasks = [
            run_scanner_task_async(  # ← 异步 Task
                tool=tool_name,
                target=target_name,
                result_dir=result_dir,
                command=config['command'],
                timeout=config['timeout']
            )
            for tool_name, config in SCANNER_CONFIGS.items()
        ]
        
        # 并行执行所有任务（支持取消）
        # return_exceptions=True: 异常作为结果返回，不中断其他任务
        results = await asyncio.gather(*tasks, return_exceptions=True)
        
        # 处理结果：过滤成功的任务
        result_files = []
        for i, result in enumerate(results):
            tool_name = list(SCANNER_CONFIGS.keys())[i]
            
            if isinstance(result, Exception):
                # 任务失败（异常）
                logger.error(
                    "扫描工具 %s 执行失败: %s",
                    tool_name, result
                )
            elif isinstance(result, str) and result:
                # 任务成功（返回文件路径）
                result_files.append(result)
                logger.debug("✓ %s 结果: %s", tool_name, result)
            else:
                # 任务失败（返回空字符串）
                logger.warning("扫描工具 %s 未返回结果", tool_name)
        
        # 检查是否所有工具都失败
        if not result_files:
            tool_names = ', '.join(SCANNER_CONFIGS.keys())
            raise RuntimeError(
                f"所有扫描工具均失败 - 目标: {target_name}. "
                f"请检查扫描工具是否正确安装（{tool_names}）"
            )
        
        logger.info(
            "✓ 扫描工具并行执行完成 - 成功: %d/%d",
            len(result_files), len(SCANNER_CONFIGS)
        )
        
        # ==================== Step 2: 合并并去重域名 ====================
        logger.info("Step 2: 合并并去重域名")
        
        # merge_and_validate_task 是同步 Task，直接调用
        # Prefect 会自动处理同步 Task 在异步 Flow 中的执行
        merged_file = merge_and_validate_task(
            result_files=result_files,
            result_dir=result_dir
        )
        
        # ==================== Step 3: 流式保存到数据库 ====================
        logger.info("Step 3: 流式保存到数据库")
        
        # save_domains_task 是同步 Task，直接调用
        saved_count = save_domains_task(
            domains_file=merged_file,
            scan_id=scan_id,
            target_id=target_id
        )
        
        # ==================== 完成 ====================
        logger.info(
            "="*60 + "\n" +
            "✓ 子域名发现扫描完成\n" +
            f"  Scan ID: {scan_id}\n" +
            f"  Target: {target_name}\n" +
            f"  发现域名: {saved_count}\n" +
            "="*60
        )
        
        # 返回结果
        executed_tasks = [f'run_scanner_async ({tool})' for tool in SCANNER_CONFIGS.keys()]
        executed_tasks.extend(['merge_and_validate', 'save_domains'])
        
        return {
            'success': True,
            'scan_id': scan_id,
            'target': target_name,
            'scan_workspace_dir': scan_workspace_dir,
            'total': saved_count,
            'executed_tasks': executed_tasks
        }
    
    except asyncio.CancelledError:
        # Flow 被取消
        logger.warning(
            "✗ 子域名发现扫描被取消\n" +
            f"  Scan ID: {scan_id}\n" +
            f"  Target: {target_name}"
        )
        # 重新抛出，让 Prefect 处理
        raise
    
    except Exception as e:
        logger.error(
            "✗ 子域名发现扫描失败\n" +
            f"  Scan ID: {scan_id}\n" +
            f"  Target: {target_name}\n" +
            f"  错误: {e}",
            exc_info=True
        )
        raise
